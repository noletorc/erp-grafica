.container{
padding:20px;
}

.topo{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.card{
background:#fff;
padding:20px;
border-radius:8px;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

table{
width:100%;
border-collapse:collapse;
}

th, td{
padding:12px;
border-bottom:1px solid #eee;
text-align:left;
}

.btn{
padding:6px 12px;
border:none;
border-radius:5px;
cursor:pointer;
color:#fff;
}

.azul{
background:#3498db;
}

.verde{
background:#2ecc71;
}

.vermelho{
background:#e74c3c;
}

.btn-novo{
background:#1abc9c;
color:white;
border:none;
padding:8px 14px;
border-radius:5px;
cursor:pointer;
}

.status{
padding:4px 8px;
border-radius:4px;
font-size:12px;
}

.pendente{
background:#f1c40f;
color:#000;
}
